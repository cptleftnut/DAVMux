<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- ── DAVMux Header ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="#0A0A0A"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="▓ DAVMux v2.0"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <!-- AI toggle button -->
        <Button
            android:id="@+id/btnAI"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="AI"
            android:textColor="#000000"
            android:backgroundTint="#00FF00"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>
    </LinearLayout>

    <!-- Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#00FF00"
        android:alpha="0.3"/>

    <!-- ── Termux TerminalView (main content) ────────────────────── -->
    <com.termux.view.TerminalView
        android:id="@+id/terminalView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000"/>

    <!-- ── AI Panel (collapsible, green theme) ───────────────────── -->
    <LinearLayout
        android:id="@+id/aiPanel"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:orientation="vertical"
        android:background="#050505"
        android:visibility="gone">

        <!-- AI panel header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:text="▓ DAVMux AI  ·  claude-sonnet-4-5"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:background="#0A0A0A"/>

        <!-- AI output scroll -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <TextView
                android:id="@+id/tvAIOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="  DAVMux AI ready. Type a message or /help\n"
                android:textColor="#00CC00"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:padding="8dp"
                android:lineSpacingExtra="2dp"/>
        </ScrollView>

        <!-- AI input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:background="#0A0A0A"
            android:paddingStart="8dp"
            android:paddingEnd="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❯ "
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/etAIInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Ask AI…"
                android:hintTextColor="#225522"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:background="@null"
                android:imeOptions="actionSend"
                android:inputType="textNoSuggestions"
                android:singleLine="true"/>

            <Button
                android:id="@+id/btnAISend"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="SEND"
                android:backgroundTint="#003300"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── Command input bar (terminal) ─────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#00FF00"
        android:alpha="0.2"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#000000"
        android:paddingStart="8dp"
        android:paddingEnd="4dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="~$ "
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="14sp"/>

        <EditText
            android:id="@+id/etCommand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="command…"
            android:hintTextColor="#225522"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:background="@null"
            android:imeOptions="actionSend"
            android:inputType="textNoSuggestions"
            android:singleLine="true"/>

        <Button
            android:id="@+id/btnRun"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="EXEC"
            android:backgroundTint="#003300"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:textSize="11sp"/>
    </LinearLayout>

</LinearLayout>
